{
  "name": "@freellmapi/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit && bun build ./src/index.ts --outdir ./dist --target node",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@freellmapi/shared": "*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}