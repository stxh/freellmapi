{
  "name": "@freellmapi/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc --noEmit && bun build ./src/server.ts --outdir ./dist --target bun --minify",
    "start": "bun dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@freellmapi/shared": "*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "bun-types": "^1.3.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}