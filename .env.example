# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001)
PORT=3001

# Hugging Face Dataset backup configuration
# HF_TOKEN: Hugging Face access token with write access to the dataset
# HF_DATASET_ID: Dataset repository ID, e.g. "username/freellmapi-backups"
# BACKUP_ENABLED: Set to "true" to enable automatic backup and restore
# BACKUP_INTERVAL_MS: Backup interval in milliseconds (default: 86400000 = 24h)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_DATASET_ID=username/freellmapi-backups
BACKUP_ENABLED=false
BACKUP_INTERVAL_MS=86400000
